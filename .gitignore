# macOS
.DS_Store

# Xcode user state — not shared across developers
*.xcuserstate
**/xcuserdata/
*.xcuserdatad/

# Build products
build/
DerivedData/

# Swift Package Manager
.swiftpm/
.build/
Package.resolved

# Terraform — state contains sensitive AWS metadata; provider cache is local.
**/.terraform/
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfstate.*.backup
**/*.tfplan
backend/infrastructure/terraform/modules/api/lambda_package_*.zip

# Node — runtime deps regenerated by deploy.sh; lockfiles ARE tracked.
backend/lambda/node_modules/
backend/scripts/node_modules/
